<Window
    Background="Transparent"
    Height="30"
    IsHitTestVisible="False"
    ShowInTaskbar="False"
    Topmost="True"
    TransparencyBackgroundFallback="Transparent"
    WindowDecorations="None"
    x:Class="Tio.Avalonia.Standard.Tab.Behavior.TabDragPreviewWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:shared="clr-namespace:TioUi.Shared;assembly=TioUi"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush Color="#ffffff" x:Key="TBackground" />
                    <SolidColorBrush Color="#e7eaed" x:Key="TBorder" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush Color="#1f2430" x:Key="TBackground" />
                    <SolidColorBrush Color="#141821" x:Key="TBorder" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border
        Background="{DynamicResource TBackground}"
        BorderBrush="{DynamicResource TBorder}"
        BorderThickness="1"
        CornerRadius="10"
        Height="30"
        HorizontalAlignment="Left"
        MinWidth="135"
        Opacity="1"
        Padding="8,6,8,6">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <PathIcon
                Height="18"
                Margin="0,0,4,0"
                VerticalAlignment="Center"
                Width="18"
                x:Name="IconPath" />
            <ContentControl
                FontSize="14"
                Margin="2,0,0,0"
                Name="Header"
                VerticalAlignment="Center" />
            <PathIcon
                Height="16"
                Margin="15,0,0,0"
                VerticalAlignment="Center"
                Width="16"
                x:Name="DragStateIcon" />
        </StackPanel>
    </Border>
</Window>